@page
@model Firmeza.Web.Pages.Clients.DeleteModel
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "Admin")]
@{
    ViewData["Title"] = "Delete Client";
}

<div class="max-w-lg">
    <a href="/Clients" class="inline-flex items-center gap-1 text-sm text-gray-500 hover:text-gray-700 mb-6">
        <i class="bi bi-arrow-left"></i> Back to Clients
    </a>

    <div class="bg-white rounded-xl shadow-sm p-8">
        <div class="flex items-center gap-4 mb-6">
            <div class="w-12 h-12 bg-red-100 rounded-xl flex items-center justify-center">
                <i class="bi bi-person-x text-red-600 text-xl"></i>
            </div>
            <div>
                <h2 class="text-lg font-semibold text-gray-900">Delete Client</h2>
                <p class="text-sm text-gray-500">This action cannot be undone</p>
            </div>
        </div>

        @if (Model.ClientName is not null)
        {
            <div class="bg-gray-50 rounded-lg p-4 mb-6">
                <p class="text-sm text-gray-500">You are about to delete:</p>
                <p class="font-semibold text-gray-900 mt-1">@Model.ClientName</p>
            </div>
        }

        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="bg-red-50 border border-red-200 text-red-700 rounded-lg px-4 py-3 mb-6 text-sm">
                @Model.ErrorMessage
            </div>
        }

        <form method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" value="@Model.ClientId" />
            <div class="flex gap-3">
                <button type="submit"
                        class="bg-red-600 hover:bg-red-700 text-white px-6 py-2.5 rounded-lg font-medium text-sm transition-colors">
                    Yes, Delete
                </button>
                <a href="/Clients"
                   class="border border-gray-300 hover:bg-gray-50 text-gray-700 px-6 py-2.5 rounded-lg font-medium text-sm transition-colors">
                    Cancel
                </a>
            </div>
        </form>
    </div>
</div>
