@page
@model Firmeza.Web.Pages.Sales.DetailModel
@using System.IO
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "Admin")]
@{
    ViewData["Title"] = $"Sale #{Model.Sale?.Id}";
}

@if (Model.Sale is null)
{
    <div class="bg-red-50 border border-red-200 text-red-700 rounded-xl px-5 py-4">
        Sale not found.
    </div>
}
else
{
    var sale = Model.Sale;
    var subtotal   = sale.Total;
    var iva        = Math.Round(subtotal * 0.19m, 2);
    var grandTotal = subtotal + iva;

    <div class="flex items-center justify-between mb-6">
        <p class="text-sm text-gray-500">Details and products included in this sale.</p>
        <div class="flex items-center gap-3">
            <a href="/Sales?handler=DownloadReceipt&id=@sale.Id" target="_blank"
               class="flex items-center gap-2 bg-red-500 hover:bg-red-400 text-white px-4 py-2 rounded-lg text-sm font-medium transition-colors">
                <i class="bi bi-file-earmark-pdf"></i> Download Receipt PDF
            </a>
            <a href="/Sales" class="flex items-center gap-2 text-sm text-gray-500 hover:text-gray-800 transition-colors">
                <i class="bi bi-arrow-left"></i> Back
            </a>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">

        <!-- Info venta + cliente -->
        <div class="space-y-5">
            <div class="bg-white rounded-xl shadow-sm p-6">
                <p class="text-xs font-semibold text-gray-400 uppercase tracking-wide mb-3">Sale Info</p>
                <div class="space-y-2 text-sm">
                    <div class="flex justify-between">
                        <span class="text-gray-500">Number</span>
                        <span class="font-mono font-semibold">#@sale.Id</span>
                    </div>
                    <div class="flex justify-between">
                        <span class="text-gray-500">Date</span>
                        <span>@sale.SaleDate.ToString("dd MMM yyyy, HH:mm")</span>
                    </div>
                    <div class="flex justify-between">
                        <span class="text-gray-500">Status</span>
                        <span class="px-2 py-0.5 rounded-full text-xs font-medium
                            @(sale.Status == "Completed" ? "bg-green-100 text-green-700" :
                              sale.Status == "Cancelled" ? "bg-red-100 text-red-700" :
                              "bg-yellow-100 text-yellow-700")">
                            @sale.Status
                        </span>
                    </div>
                </div>
            </div>
            <div class="bg-white rounded-xl shadow-sm p-6">
                <p class="text-xs font-semibold text-gray-400 uppercase tracking-wide mb-3">Client</p>
                <div class="space-y-2 text-sm">
                    <p class="font-semibold text-gray-800">@sale.Client.FullName</p>
                    <p class="text-gray-500">@sale.Client.DocumentType @sale.Client.DocumentNumber</p>
                    <p class="text-gray-500">@sale.Client.Email</p>
                    <p class="text-gray-500">@sale.Client.Phone</p>
                </div>
            </div>
        </div>

        <!-- Productos -->
        <div class="lg:col-span-2">
            <div class="bg-white rounded-xl shadow-sm overflow-hidden">
                <div class="px-6 py-4 border-b border-gray-100">
                    <h2 class="font-semibold text-gray-700">Products</h2>
                </div>
                <table class="w-full text-sm">
                    <thead class="bg-gray-50 text-gray-400 uppercase text-xs border-b border-gray-100">
                        <tr>
                            <th class="px-5 py-3 text-left">Product</th>
                            <th class="px-5 py-3 text-center">Qty</th>
                            <th class="px-5 py-3 text-right">Unit Price</th>
                            <th class="px-5 py-3 text-right">Subtotal</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-100">
                        @foreach (var d in sale.Details)
                        {
                            <tr class="hover:bg-gray-50">
                                <td class="px-5 py-3 font-medium text-gray-800">@d.Product.Name</td>
                                <td class="px-5 py-3 text-center text-gray-600">@d.Quantity</td>
                                <td class="px-5 py-3 text-right text-gray-600">$@d.UnitPrice.ToString("N2")</td>
                                <td class="px-5 py-3 text-right font-semibold text-gray-800">$@d.Subtotal.ToString("N2")</td>
                            </tr>
                        }
                    </tbody>
                    <tfoot class="bg-gray-50 text-sm border-t border-gray-200">
                        <tr>
                            <td colspan="3" class="px-5 py-3 text-right text-gray-500">Subtotal</td>
                            <td class="px-5 py-3 text-right">$@subtotal.ToString("N2")</td>
                        </tr>
                        <tr>
                            <td colspan="3" class="px-5 py-3 text-right text-gray-500">IVA (19%)</td>
                            <td class="px-5 py-3 text-right">$@iva.ToString("N2")</td>
                        </tr>
                        <tr class="font-bold text-gray-800">
                            <td colspan="3" class="px-5 py-3 text-right">TOTAL</td>
                            <td class="px-5 py-3 text-right text-yellow-600 text-base">$@grandTotal.ToString("N2")</td>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </div>
    </div>
}
