@page
@model Firmeza.Web.Pages.Auth.LoginModel
@{
    Layout = null; // Login no usa el sidebar
    ViewData["Title"] = "Sign In";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Sign In – Firmeza</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <style> body { font-family: 'Inter', sans-serif; } </style>
</head>
<body class="bg-slate-900 min-h-screen flex items-center justify-center">

    <div class="w-full max-w-md px-4">

        <!-- Card -->
        <div class="bg-white rounded-2xl shadow-2xl p-8">

            <!-- Logo -->
            <div class="text-center mb-8">
                <div class="inline-flex items-center justify-center w-16 h-16 bg-yellow-500 rounded-2xl mb-4">
                    <i class="bi bi-building text-white text-3xl"></i>
                </div>
                <h1 class="text-2xl font-bold text-gray-900">Firmeza</h1>
                <p class="text-gray-500 text-sm mt-1">Sign in to the admin panel</p>
            </div>

            <!-- Mensaje de error -->
            @if (TempData["SuccessMessage"] is string success)
            {
                <div class="bg-green-50 border border-green-200 text-green-700 rounded-lg px-4 py-3 mb-6 flex items-center gap-2">
                    <i class="bi bi-check-circle-fill"></i>
                    <span class="text-sm">@success</span>
                </div>
            }

            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div class="bg-red-50 border border-red-200 text-red-700 rounded-lg px-4 py-3 mb-6 flex items-center gap-2">
                    <i class="bi bi-exclamation-circle-fill"></i>
                    <span class="text-sm">@Model.ErrorMessage</span>
                </div>
            }

            <!-- Formulario -->
            <form method="post" class="space-y-5">
                @Html.AntiForgeryToken()

                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Email</label>
                    <div class="relative">
                        <i class="bi bi-envelope absolute left-3 top-1/2 -translate-y-1/2 text-gray-400"></i>
                        <input asp-for="Input.Email" type="email"
                               class="w-full pl-10 pr-4 py-2.5 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-yellow-500 text-sm"
                               placeholder="admin@firmeza.com" />
                    </div>
                    <span asp-validation-for="Input.Email" class="text-red-500 text-xs mt-1"></span>
                </div>

                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Password</label>
                    <div class="relative">
                        <i class="bi bi-lock absolute left-3 top-1/2 -translate-y-1/2 text-gray-400"></i>
                        <input asp-for="Input.Password" type="password"
                               class="w-full pl-10 pr-4 py-2.5 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-yellow-500 text-sm"
                               placeholder="••••••••" />
                    </div>
                    <span asp-validation-for="Input.Password" class="text-red-500 text-xs mt-1"></span>
                </div>

                <div class="flex items-center gap-2">
                    <input asp-for="Input.RememberMe" type="checkbox" id="rememberMe"
                           class="w-4 h-4 accent-yellow-500" />
                    <label for="rememberMe" class="text-sm text-gray-600">Remember me</label>
                </div>

                <button type="submit"
                        class="w-full bg-yellow-500 hover:bg-yellow-600 text-white font-semibold py-2.5 rounded-lg transition-colors">
                    Sign In
                </button>
            </form>

            <p class="text-center text-xs text-gray-400 mt-6">
                Default admin: admin&#64;firmeza.com / Admin123!
            </p>

            <hr class="my-5 border-gray-200" />

            <p class="text-center text-sm text-gray-500">
                Don't have an account?
                <a href="/Auth/Register" class="text-yellow-600 hover:underline font-medium">Create one</a>
            </p>
        </div>
    </div>

</body>
</html>
