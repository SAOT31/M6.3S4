@page
@model Firmeza.Web.Pages.Auth.AccessDeniedModel
@{
    Layout = null;
    ViewData["Title"] = "Access Denied";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>Access Denied – Firmeza</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600&display=swap" rel="stylesheet">
    <style> body { font-family: 'Inter', sans-serif; } </style>
</head>
<body class="bg-slate-900 min-h-screen flex items-center justify-center">
    <div class="text-center">
        <p class="text-8xl font-bold text-yellow-500 mb-4">403</p>
        <h1 class="text-2xl font-semibold text-white mb-2">Access Denied</h1>
        <p class="text-slate-400 mb-8">You don't have permission to access the admin panel.</p>
        <a href="/Auth/Login"
           class="bg-yellow-500 hover:bg-yellow-600 text-white px-6 py-2.5 rounded-lg font-medium transition-colors">
            Back to Login
        </a>
    </div>
</body>
</html>
