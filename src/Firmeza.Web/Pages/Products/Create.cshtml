@page
@model Firmeza.Web.Pages.Products.CreateModel
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "Admin")]
@{
    ViewData["Title"] = "New Product";
}

<div class="max-w-2xl">
    <a href="/Products" class="inline-flex items-center gap-1 text-sm text-gray-500 hover:text-gray-700 mb-6">
        <i class="bi bi-arrow-left"></i> Back to Products
    </a>

    <div class="bg-white rounded-xl shadow-sm p-8">

        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="bg-red-50 border border-red-200 text-red-700 rounded-lg px-4 py-3 mb-6 text-sm flex items-center gap-2">
                <i class="bi bi-exclamation-circle-fill"></i>
                @Model.ErrorMessage
            </div>
        }

        <form method="post" class="space-y-5">
            @Html.AntiForgeryToken()

            <!-- Name -->
            <div>
                <label asp-for="Product.Name" class="block text-sm font-medium text-gray-700 mb-1"></label>
                <input asp-for="Product.Name"
                       class="w-full border border-gray-300 rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-yellow-500"
                       placeholder="e.g. Gray Cement 50kg" />
                <span asp-validation-for="Product.Name" class="text-red-500 text-xs mt-1 block"></span>
            </div>

            <!-- Description -->
            <div>
                <label asp-for="Product.Description" class="block text-sm font-medium text-gray-700 mb-1"></label>
                <textarea asp-for="Product.Description" rows="3"
                          class="w-full border border-gray-300 rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-yellow-500 resize-none"
                          placeholder="Optional product description..."></textarea>
            </div>

            <!-- Category + Unit -->
            <div class="grid grid-cols-2 gap-4">
                <div>
                    <label asp-for="Product.Category" class="block text-sm font-medium text-gray-700 mb-1"></label>
                    <select asp-for="Product.Category"
                            class="w-full border border-gray-300 rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-yellow-500">
                        <option value="">Select category...</option>
                        @foreach (var cat in Firmeza.Web.ViewModels.ProductViewModel.Categories)
                        {
                            <option value="@cat">@cat</option>
                        }
                    </select>
                    <span asp-validation-for="Product.Category" class="text-red-500 text-xs mt-1 block"></span>
                </div>
                <div>
                    <label asp-for="Product.Unit" class="block text-sm font-medium text-gray-700 mb-1"></label>
                    <select asp-for="Product.Unit"
                            class="w-full border border-gray-300 rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-yellow-500">
                        <option value="">Select unit...</option>
                        @foreach (var unit in Firmeza.Web.ViewModels.ProductViewModel.Units)
                        {
                            <option value="@unit">@unit</option>
                        }
                    </select>
                    <span asp-validation-for="Product.Unit" class="text-red-500 text-xs mt-1 block"></span>
                </div>
            </div>

            <!-- Price + Stock -->
            <div class="grid grid-cols-2 gap-4">
                <div>
                    <label asp-for="Product.Price" class="block text-sm font-medium text-gray-700 mb-1"></label>
                    <div class="relative">
                        <span class="absolute left-3 top-1/2 -translate-y-1/2 text-gray-400 text-sm">$</span>
                        <input asp-for="Product.Price" type="number" step="0.01" min="0"
                               class="w-full pl-7 border border-gray-300 rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-yellow-500"
                               placeholder="0.00" />
                    </div>
                    <span asp-validation-for="Product.Price" class="text-red-500 text-xs mt-1 block"></span>
                </div>
                <div>
                    <label asp-for="Product.Stock" class="block text-sm font-medium text-gray-700 mb-1"></label>
                    <input asp-for="Product.Stock" type="number" min="0"
                           class="w-full border border-gray-300 rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-yellow-500"
                           placeholder="0" />
                    <span asp-validation-for="Product.Stock" class="text-red-500 text-xs mt-1 block"></span>
                </div>
            </div>

            <div class="flex gap-3 pt-2">
                <button type="submit"
                        class="bg-yellow-500 hover:bg-yellow-600 text-white px-6 py-2.5 rounded-lg font-medium text-sm transition-colors">
                    Save Product
                </button>
                <a href="/Products"
                   class="border border-gray-300 hover:bg-gray-50 text-gray-700 px-6 py-2.5 rounded-lg font-medium text-sm transition-colors">
                    Cancel
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
