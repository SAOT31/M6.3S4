@page
@model Firmeza.Web.Pages.Products.IndexModel
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "Admin")]
@{
    ViewData["Title"] = "Products";
}

<!-- Barra superior: título + botón nuevo -->
<div class="flex items-center justify-between mb-6">
    <div>
        <p class="text-sm text-gray-500">Manage your product catalog</p>
    </div>
    <a href="/Products/Create"
       class="inline-flex items-center gap-2 bg-yellow-500 hover:bg-yellow-600 text-white px-4 py-2 rounded-lg font-medium transition-colors text-sm">
        <i class="bi bi-plus-lg"></i> New Product
    </a>
</div>

<!-- Buscador y filtro -->
<form method="get" class="bg-white rounded-xl shadow-sm p-4 mb-5 flex gap-3 flex-wrap">
    <input type="text" name="search" value="@Model.Search"
           placeholder="Search by name..."
           class="flex-1 min-w-48 border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-yellow-500" />
    <select name="category"
            class="border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-yellow-500">
        <option value="">All Categories</option>
        @foreach (var cat in Firmeza.Web.ViewModels.ProductViewModel.Categories)
        {
            <option value="@cat" selected="@(Model.Category == cat)">@cat</option>
        }
    </select>
    <button type="submit"
            class="bg-slate-800 hover:bg-slate-700 text-white px-4 py-2 rounded-lg text-sm transition-colors">
        <i class="bi bi-search"></i> Search
    </button>
    @if (!string.IsNullOrEmpty(Model.Search) || !string.IsNullOrEmpty(Model.Category))
    {
        <a href="/Products" class="border border-gray-300 hover:bg-gray-50 text-gray-600 px-4 py-2 rounded-lg text-sm transition-colors">
            Clear
        </a>
    }
</form>

<!-- Tabla de productos -->
<div class="bg-white rounded-xl shadow-sm overflow-hidden">
    <table class="w-full text-sm">
        <thead class="bg-gray-50 text-gray-500 uppercase text-xs border-b border-gray-100">
            <tr>
                <th class="px-5 py-3 text-left">Product</th>
                <th class="px-5 py-3 text-left">Category</th>
                <th class="px-5 py-3 text-left">Price</th>
                <th class="px-5 py-3 text-left">Stock</th>
                <th class="px-5 py-3 text-left">Unit</th>
                <th class="px-5 py-3 text-center">Actions</th>
            </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
            @if (!Model.Products.Any())
            {
                <tr>
                    <td colspan="6" class="py-12 text-center text-gray-400">
                        <i class="bi bi-box-seam text-3xl mb-2 block"></i>
                        No products found
                    </td>
                </tr>
            }
            @foreach (var p in Model.Products)
            {
                <tr class="hover:bg-gray-50 transition-colors">
                    <td class="px-5 py-4">
                        <p class="font-medium text-gray-900">@p.Name</p>
                        <p class="text-xs text-gray-400 truncate max-w-xs">@p.Description</p>
                    </td>
                    <td class="px-5 py-4">
                        <span class="bg-blue-50 text-blue-700 text-xs px-2 py-1 rounded-full">@p.Category</span>
                    </td>
                    <td class="px-5 py-4 font-semibold text-gray-800">$@p.Price.ToString("N2")</td>
                    <td class="px-5 py-4">
                        <span class="font-semibold @(p.Stock < 10 ? "text-red-600" : "text-gray-800")">
                            @p.Stock
                        </span>
                        @if (p.Stock < 10)
                        {
                            <span class="ml-1 text-xs text-red-400"><i class="bi bi-exclamation-triangle-fill"></i></span>
                        }
                    </td>
                    <td class="px-5 py-4 text-gray-500">@p.Unit</td>
                    <td class="px-5 py-4 text-center">
                        <div class="inline-flex gap-2">
                            <a href="/Products/Edit?id=@p.Id"
                               class="p-1.5 text-slate-600 hover:text-yellow-600 hover:bg-yellow-50 rounded-lg transition-colors" title="Edit">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <a href="/Products/Delete?id=@p.Id"
                               class="p-1.5 text-slate-600 hover:text-red-600 hover:bg-red-50 rounded-lg transition-colors" title="Delete">
                                <i class="bi bi-trash"></i>
                            </a>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
    <div class="px-5 py-3 border-t border-gray-100 text-xs text-gray-400">
        @Model.Products.Count product(s) found
    </div>
</div>
