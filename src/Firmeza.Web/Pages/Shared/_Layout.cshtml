<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Firmeza - Construction Materials Administration Panel" />
    <title>@ViewData["Title"] – Firmeza Admin</title>

    <!-- Tailwind CSS via Play CDN -->
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        // Configuración del tema personalizado
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        brand: {
                            50:  '#fefce8',
                            100: '#fef9c3',
                            500: '#eab308',
                            600: '#ca8a04',
                            700: '#a16207',
                            900: '#713f12',
                        },
                        sidebar: '#1e293b',
                    }
                }
            }
        }
    </script>

    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">

    <style>
        body { font-family: 'Inter', sans-serif; }
    </style>
</head>
<body class="bg-gray-100 min-h-screen flex">

    <!-- ── Sidebar ─────────────────────────────────────────────────────────── -->
    <aside class="w-64 min-h-screen bg-sidebar text-white flex flex-col fixed top-0 left-0 z-30">

        <!-- Logo -->
        <div class="px-6 py-5 border-b border-slate-700">
            <div class="flex items-center gap-3">
                <span class="text-brand-500 text-2xl"><i class="bi bi-building"></i></span>
                <div>
                    <p class="text-white font-bold text-lg leading-none">Firmeza</p>
                    <p class="text-slate-400 text-xs">Admin Panel</p>
                </div>
            </div>
        </div>

        <!-- Navegación -->
        <nav class="flex-1 px-4 py-5 space-y-1">

            <p class="text-xs text-slate-500 uppercase tracking-widest px-2 mb-2">Main</p>

            <a href="/Dashboard"
               class="flex items-center gap-3 px-3 py-2 rounded-lg text-slate-300 hover:bg-slate-700 hover:text-white transition-colors @(ViewContext.RouteData.Values["page"]?.ToString()?.StartsWith("/Dashboard") == true ? "bg-brand-700 text-white" : "")">
                <i class="bi bi-speedometer2 text-lg"></i>
                <span>Dashboard</span>
            </a>

            <p class="text-xs text-slate-500 uppercase tracking-widest px-2 mt-4 mb-2">Catalog</p>

            <a href="/Products"
               class="flex items-center gap-3 px-3 py-2 rounded-lg text-slate-300 hover:bg-slate-700 hover:text-white transition-colors @(ViewContext.RouteData.Values["page"]?.ToString()?.StartsWith("/Products") == true ? "bg-brand-700 text-white" : "")">
                <i class="bi bi-box-seam text-lg"></i>
                <span>Products</span>
            </a>

            <a href="/Clients"
               class="flex items-center gap-3 px-3 py-2 rounded-lg text-slate-300 hover:bg-slate-700 hover:text-white transition-colors @(ViewContext.RouteData.Values["page"]?.ToString()?.StartsWith("/Clients") == true ? "bg-brand-700 text-white" : "")">
                <i class="bi bi-people text-lg"></i>
                <span>Clients</span>
            </a>

            <a href="/Sales"
               class="flex items-center gap-3 px-3 py-2 rounded-lg text-slate-300 hover:bg-slate-700 hover:text-white transition-colors @(ViewContext.RouteData.Values["page"]?.ToString()?.StartsWith("/Sales") == true ? "bg-brand-700 text-white" : "")">
                <i class="bi bi-receipt text-lg"></i>
                <span>Sales</span>
            </a>

            <p class="text-xs text-slate-500 uppercase tracking-widest px-2 mt-4 mb-2">Tools</p>

            <a href="/Import"
               class="flex items-center gap-3 px-3 py-2 rounded-lg text-slate-300 hover:bg-slate-700 hover:text-white transition-colors @(ViewContext.RouteData.Values["page"]?.ToString()?.StartsWith("/Import") == true ? "bg-brand-700 text-white" : "")">
                <i class="bi bi-upload text-lg"></i>
                <span>Import</span>
            </a>

            <a href="/Export"
               class="flex items-center gap-3 px-3 py-2 rounded-lg text-slate-300 hover:bg-slate-700 hover:text-white transition-colors @(ViewContext.RouteData.Values["page"]?.ToString()?.StartsWith("/Export") == true ? "bg-brand-700 text-white" : "")">
                <i class="bi bi-download text-lg"></i>
                <span>Export</span>
            </a>

        <!-- Footer del sidebar con info del usuario -->
        <div class="px-4 py-4 border-t border-slate-700">
            @if (User.Identity?.IsAuthenticated == true)
            {
                <div class="flex items-center gap-3">
                    <div class="w-8 h-8 bg-brand-600 rounded-full flex items-center justify-center">
                        <i class="bi bi-person text-white text-sm"></i>
                    </div>
                    <div class="flex-1 min-w-0">
                        <p class="text-white text-sm truncate">@User.Identity.Name</p>
                        <p class="text-slate-400 text-xs">Administrator</p>
                    </div>
                    <form method="post" action="/Auth/Logout">
                        @Html.AntiForgeryToken()
                        <button type="submit" title="Logout"
                                class="text-slate-400 hover:text-red-400 transition-colors">
                            <i class="bi bi-box-arrow-right"></i>
                        </button>
                    </form>
                </div>
            }
        </div>
    </aside>

    <!-- ── Contenido principal ─────────────────────────────────────────────── -->
    <div class="ml-64 flex-1 flex flex-col min-h-screen">

        <!-- Topbar -->
        <header class="bg-white border-b border-gray-200 px-6 py-4 flex items-center justify-between sticky top-0 z-20">
            <h1 class="text-xl font-semibold text-gray-800">@ViewData["Title"]</h1>
            <div class="flex items-center gap-3">
                <span class="text-sm text-gray-500">@DateTime.Now.ToString("MMM dd, yyyy")</span>
            </div>
        </header>

        @if (TempData["Success"] is string successMsg)
        {
            <div class="mx-6 mt-4 bg-green-50 border border-green-200 text-green-700 rounded-xl px-5 py-3 flex items-center gap-3 text-sm">
                <i class="bi bi-check-circle-fill"></i>
                <span>@successMsg</span>
            </div>
        }

        <!-- Página -->
        <main class="flex-1 p-6">
            @RenderBody()
        </main>

        <!-- Footer -->
        <footer class="bg-white border-t border-gray-200 px-6 py-3 text-center text-xs text-gray-400">
            Firmeza © @DateTime.Now.Year — Construction Materials Management System
        </footer>
    </div>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
