@page
@model Firmeza.Web.Pages.Export.IndexModel
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "Admin")]
@{
    ViewData["Title"] = "Export Data";
}

<div class="flex items-center justify-between mb-6">
    <p class="text-sm text-gray-500">Download data as Excel or PDF files for reports and backups.</p>
</div>

<div class="grid grid-cols-1 md:grid-cols-3 gap-6">

    <!-- Productos -->
    <div class="bg-white rounded-xl shadow-sm p-6">
        <div class="flex items-center gap-3 mb-5">
            <div class="w-10 h-10 bg-yellow-100 rounded-lg flex items-center justify-center">
                <i class="bi bi-box-seam text-yellow-600 text-lg"></i>
            </div>
            <div>
                <h2 class="font-semibold text-gray-800">Products</h2>
                <p class="text-xs text-gray-400">@Model.ProductCount records</p>
            </div>
        </div>
        <div class="space-y-2">
            <a href="/Export?handler=ProductsExcel"
               class="flex items-center gap-2 w-full justify-center bg-green-600 hover:bg-green-500 text-white px-4 py-2.5 rounded-lg text-sm font-medium transition-colors">
                <i class="bi bi-file-earmark-excel"></i> Download Excel
            </a>
            <a href="/Export?handler=ProductsPdf"
               class="flex items-center gap-2 w-full justify-center bg-red-500 hover:bg-red-400 text-white px-4 py-2.5 rounded-lg text-sm font-medium transition-colors">
                <i class="bi bi-file-earmark-pdf"></i> Download PDF
            </a>
        </div>
    </div>

    <!-- Clientes -->
    <div class="bg-white rounded-xl shadow-sm p-6">
        <div class="flex items-center gap-3 mb-5">
            <div class="w-10 h-10 bg-blue-100 rounded-lg flex items-center justify-center">
                <i class="bi bi-people text-blue-600 text-lg"></i>
            </div>
            <div>
                <h2 class="font-semibold text-gray-800">Clients</h2>
                <p class="text-xs text-gray-400">@Model.ClientCount records</p>
            </div>
        </div>
        <div class="space-y-2">
            <a href="/Export?handler=ClientsExcel"
               class="flex items-center gap-2 w-full justify-center bg-green-600 hover:bg-green-500 text-white px-4 py-2.5 rounded-lg text-sm font-medium transition-colors">
                <i class="bi bi-file-earmark-excel"></i> Download Excel
            </a>
            <a href="/Export?handler=ClientsPdf"
               class="flex items-center gap-2 w-full justify-center bg-red-500 hover:bg-red-400 text-white px-4 py-2.5 rounded-lg text-sm font-medium transition-colors">
                <i class="bi bi-file-earmark-pdf"></i> Download PDF
            </a>
        </div>
    </div>

    <!-- Ventas -->
    <div class="bg-white rounded-xl shadow-sm p-6">
        <div class="flex items-center gap-3 mb-5">
            <div class="w-10 h-10 bg-purple-100 rounded-lg flex items-center justify-center">
                <i class="bi bi-receipt text-purple-600 text-lg"></i>
            </div>
            <div>
                <h2 class="font-semibold text-gray-800">Sales</h2>
                <p class="text-xs text-gray-400">@Model.SaleCount records</p>
            </div>
        </div>
        <div class="space-y-2">
            <a href="/Export?handler=SalesExcel"
               class="flex items-center gap-2 w-full justify-center bg-green-600 hover:bg-green-500 text-white px-4 py-2.5 rounded-lg text-sm font-medium transition-colors">
                <i class="bi bi-file-earmark-excel"></i> Download Excel
            </a>
            <a href="/Export?handler=SalesPdf"
               class="flex items-center gap-2 w-full justify-center bg-red-500 hover:bg-red-400 text-white px-4 py-2.5 rounded-lg text-sm font-medium transition-colors">
                <i class="bi bi-file-earmark-pdf"></i> Download PDF
            </a>
        </div>
    </div>

</div>
